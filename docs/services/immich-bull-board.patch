@@ -0,0 +1,32 @@
+import { Injectable, NestMiddleware } from '@nestjs/common';
+import { Request, Response, NextFunction } from 'express';
+import { LOGIN_URL } from 'src/constants';
+import { AuthService } from 'src/services/auth.service';
+
+@Injectable()
+export class BullBoardAuthMiddleware implements NestMiddleware {
+  constructor(private authService: AuthService) {}
+
+  async use(request: Request, response: Response, next: NextFunction) {
+    try {
+      const authDto = await this.authService.authenticate({
+        headers: request.headers,
+        queryParams: request.query as Record<string, string>,
+        metadata: { adminRoute: true, sharedLinkRoute: false, uri: request.path },
+      });
+
+      if (!authDto.user.isAdmin) {
+        response.status(403).send('Forbidden');
+        return;
+      }
+
+      next();
+    } catch {
+      if (request.accepts('html')) {
+        response.redirect(LOGIN_URL);
+        return;
+      }
+      response.status(401).send('Unauthorized');
+    }
+  }
+}
diff --git a/server/src/modules/bull-board.module.ts b/server/src/modules/bull-board.module.ts
new file mode 100644
index 000000000..0a487d50d
--- /dev/null
+++ b/server/src/modules/bull-board.module.ts
@@ -0,0 +1,26 @@
+import { BullMQAdapter } from '@bull-board/api/bullMQAdapter';
+import { BullBoardModule } from '@bull-board/nestjs';
+import { ExpressAdapter } from '@bull-board/express';
+import { MiddlewareConsumer, Module, NestModule } from '@nestjs/common';
+import { QueueName } from 'src/enum';
+import { BullBoardAuthMiddleware } from 'src/middleware/bull-board-auth.middleware';
+
+@Module({
+  imports: [
+    BullBoardModule.forRoot({
+      route: '/admin/queues',
+      adapter: ExpressAdapter,
+    }),
+    BullBoardModule.forFeature(
+      ...Object.values(QueueName).map((name) => ({
+        name,
+        adapter: BullMQAdapter,
+      })),
+    ),
+  ],
+})
+export class ImmichBullBoardModule implements NestModule {
+  configure(consumer: MiddlewareConsumer) {
+    consumer.apply(BullBoardAuthMiddleware).forRoutes('/admin/queues');
+  }
+}
