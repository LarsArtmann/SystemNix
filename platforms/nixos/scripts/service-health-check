#!/usr/bin/env bash
# Service health checker for evo-x2
# Checks systemd service state and sends desktop notification on failure.
# Gatus handles HTTP/TCP endpoint monitoring — this script focuses on systemd state only.
set -euo pipefail

export DISPLAY=:0
export WAYLAND_DISPLAY=wayland-1
export XDG_RUNTIME_DIR=/run/user/$(id -u)

FAILED=""
TOTAL=0

check_service() {
    TOTAL=$((TOTAL + 1))
    if systemctl is-active --quiet "$1" 2>/dev/null; then
        return 0
    else
        FAILED="$FAILED\n  $1"
        return 1
    fi
}

check_user_service() {
    TOTAL=$((TOTAL + 1))
    if systemctl --user is-active --quiet "$1" 2>/dev/null; then
        return 0
    else
        FAILED="$FAILED\n  $1 (user)"
        return 1
    fi
}

# === System services ===
check_service forgejo
check_service caddy
check_service unbound
check_service dnsblockd
check_service postgresql
check_service homepage-dashboard
check_service immich-server
check_service immich-machine-learning
check_service signoz
check_service signoz-collector
check_service clickhouse
check_service pocket-id
check_service oauth2-proxy
check_service gatus
check_service prometheus-node-exporter
check_service cadvisor
check_service taskchampion-sync-server
check_service hermes
check_service manifest
check_service twenty
check_service openseo
check_service docker
check_service route-health-monitor
check_service mptcp-endpoint-manager

# === User services (graphical session) ===
check_user_service waybar
check_user_service awww-daemon
check_user_service swayidle
check_user_service emeet-pixyd
check_user_service niri-session-manager
check_user_service monitor365
check_user_service monitor365-server

# === Report ===
if [ -n "$FAILED" ]; then
    FAILED_COUNT=$((TOTAL - (TOTAL - $(echo -e "$FAILED" | grep -c '.' 2>/dev/null || echo 0))))
    notify-send -u critical "Health Check: services down" "$(echo -e "$FAILED")" 2>/dev/null || true
    echo "FAILED:$(echo -e "$FAILED")"
    exit 1
else
    echo "OK: $TOTAL/$TOTAL services active"
    exit 0
fi
