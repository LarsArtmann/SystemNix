#!/usr/bin/env bash
# Pre-commit hook for NixOS configuration validation
# Only lints staged files — not the entire codebase

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

cd "$(git rev-parse --show-toplevel)"

if [ ! -f "flake.nix" ]; then
    exit 0
fi

STAGED_NIX=$(git diff --cached --name-only --diff-filter=ACM '*.nix')
all_passed=true

# Gitleaks
log_info "Running gitleaks (secret detector)..."
if gitleaks detect --source . > /tmp/gitleaks.log 2>&1; then
    log_success "Gitleaks passed! No secrets found."
elif grep -q "No leaks found\|commits scanned" /tmp/gitleaks.log; then
    log_success "Gitleaks passed! No secrets found."
fi

# Trailing whitespace on staged files only
log_info "Removing trailing whitespace..."
git diff --cached --name-only --diff-filter=ACM | while read -r f; do
    if [ -f "$f" ]; then
        /run/current-system/sw/bin/sed -i 's/[[:space:]]*$//' "$f" 2>/dev/null || true
        git add "$f" 2>/dev/null || true
    fi
done
log_success "Trailing whitespace removed."

# Only run Nix linters if staged .nix files exist
if [ -n "$STAGED_NIX" ]; then
    log_info "Running deadnix (dead code detector) on staged files..."
    if echo "$STAGED_NIX" | xargs nix shell nixpkgs#deadnix --command deadnix > /tmp/deadnix.log 2>&1; then
        log_success "Deadnix passed! No dead code found."
    else
        log_error "Deadnix found issues!"
        cat /tmp/deadnix.log
        all_passed=false
    fi

    log_info "Running statix (Nix linter)..."
    if nix shell nixpkgs#statix --command statix check -o errfmt . 2>&1 | grep -v ':E:0:' > /tmp/statix.log; then
        log_success "Statix passed! No antipatterns found."
    else
        if [ -s /tmp/statix.log ]; then
            log_error "Statix found issues in staged files!"
            cat /tmp/statix.log
            all_passed=false
        else
            log_success "Statix passed! No antipatterns found."
        fi
    fi

    log_info "Running alejandra (formatter check) on staged files..."
    if echo "$STAGED_NIX" | xargs nix shell nixpkgs#alejandra --command alejandra --check > /tmp/alejandra.log 2>&1; then
        log_success "Alejandra passed! Code is properly formatted."
    else
        log_error "Alejandra found formatting issues!"
        cat /tmp/alejandra.log
        all_passed=false
    fi
else
    log_info "No staged .nix files — skipping Nix linters."
fi

# Nix flake check always runs (validates whole config)
log_info "Running Nix flake check..."
if nix flake check > /tmp/nix-check.log 2>&1; then
    log_success "Nix flake check passed!"
else
    log_error "Nix flake check failed!"
    cat /tmp/nix-check.log
    all_passed=false
fi

if [ "$all_passed" = true ]; then
    log_success "🎉 All validation checks passed!"
    echo -e "${GREEN}Ready to commit!${NC}"
    exit 0
else
    log_error "❌ Some validation checks failed. Commit aborted."
    echo -e "${YELLOW}Fix staged files and try again.${NC}"
    exit 1
fi
